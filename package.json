{
  "dependencies": {
    "@libsql/client": "^0.15.15",
    "@sinonjs/fake-timers": "^15.0.0",
    "axios": "^1.13.2",
    "bcrypt": "^6.0.0",
    "better-sqlite3": "^12.4.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.2.2",
    "drizzle-orm": "^0.44.5",
    "express": "^5.1.0",
    "jsonwebtoken": "^9.0.2",
    "luxon": "^3.7.2",
    "node-cron": "^4.2.1",
    "nodemailer": "^7.0.10",
    "redis": "^5.10.0",
    "winston": "^3.17.0",
    "zod": "^4.1.11"
  },
  "scripts": {
    "watch": "tsc --watch --incremental",
    "dev": "nodemon",
    "test": "jest",
    "test:auth:session": "jest \"session-management.test.ts\"",
    "test:auth:minimal": "jest \"minimal-authentication.test.ts\"",
    "test:broker": "jest \"session-broker.test.ts\" ",
    "test:broker:sign-out": "jest \"session-broker.sign-out.test.ts\"",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:generate": "drizzle-kit generate --config=./config/drizzle.config.ts",
    "db:migrate": "drizzle-kit migrate --config=./config/drizzle.config.ts",
    "db:studio": "drizzle-kit studio --config=./config/drizzle.config.ts",
    "db:push": "drizzle-kit push --config=./config/drizzle.config.ts",
    "db:seed": "tsc && node ./build/scripts/seeders/seed-all.seeder.js",
    "test:enrollments": "tsc && node ./build/tests/enrollments.test.js"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cookie-parser": "^1.4.9",
    "@types/cors": "^2.8.19",
    "@types/dotenv": "^6.1.1",
    "@types/express": "^5.0.3",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/luxon": "^3.7.1",
    "@types/node": "^24.5.2",
    "@types/nodemailer": "^7.0.3",
    "@types/supertest": "^7.2.0",
    "drizzle-kit": "^0.31.4",
    "jest": "^30.3.0",
    "nodemon": "^3.1.10",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}
